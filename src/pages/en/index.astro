---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { AUTHOR } from "../../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Federico Upegui | Node.js Backend & DevOps Developer"
      description="Node.js Backend & DevOps developer based in Medellín, Colombia. I build APIs, microservices and AWS cloud infrastructure with Docker, CI/CD and AI automation."
      lang="en"
      selfPath="/en/"
      altPath="/"
    />
  </head>
  <body>
    <Header lang="en" altPath="/" />
    <main>
      <section class="hero">
        <p class="eyebrow">Hi, I'm Federico 👋</p>
        <h1>Node.js Backend <span class="amp">&amp;</span> DevOps Developer</h1>
        <p class="lead">
          I build APIs, microservices and cloud infrastructure that scale. 4+ years working
          with JavaScript and TypeScript from Medellín, Colombia — currently at
          <strong>Scalboost</strong>, combining Node.js backend work with DevOps on AWS.
        </p>
        <div class="cta">
          <a class="btn primary" href={`mailto:${AUTHOR.email}`}>Get in touch</a>
          <a class="btn" href="/en/cv">View resume</a>
          <a class="btn" href="/CV-Federico-Upegui-EN.pdf" download>Download resume (PDF)</a>
        </div>
      </section>

      <section>
        <h2>What I can help you with</h2>
        <div class="grid">
          <article>
            <h3>APIs &amp; backends</h3>
            <p>
              REST and GraphQL APIs with Node.js, NestJS and TypeScript. Microservice
              architectures, authentication and web security, ORMs and testing.
            </p>
          </article>
          <article>
            <h3>DevOps &amp; infrastructure</h3>
            <p>
              AWS deployments, Docker containers, CI/CD pipelines on Azure DevOps and
              observability so your product stays up when it matters most.
            </p>
          </article>
          <article>
            <h3>AI automation</h3>
            <p>
              Automation workflows with n8n and AI integrations that remove repetitive
              work for businesses and product teams.
            </p>
          </article>
        </div>
      </section>

      <section>
        <h2>Core stack</h2>
        <ul class="stack">
          <li>Node.js</li>
          <li>TypeScript</li>
          <li>NestJS</li>
          <li>GraphQL</li>
          <li>REST APIs</li>
          <li>Microservices</li>
          <li>AWS</li>
          <li>Docker</li>
          <li>CI/CD</li>
          <li>Azure DevOps</li>
          <li>React</li>
          <li>Next.js</li>
          <li>Astro</li>
          <li>n8n</li>
          <li>Observability</li>
        </ul>
      </section>

      <section>
        <h2>Recent experience</h2>
        <ul class="timeline">
          <li>
            <strong>Scalboost</strong> — Node.js Backend &amp; DevOps Developer
            <span class="dates">Jul 2024 – present · Medellín</span>
          </li>
          <li>
            <strong>One Consultants SAS</strong> — FullStack JavaScript Developer
            <span class="dates">Sep 2022 – Mar 2024 · Medellín</span>
          </li>
          <li>
            <strong>e-manager</strong> — Full stack web developer
            <span class="dates">Mar 2022 – Aug 2022</span>
          </li>
        </ul>
        <p><a href="/en/cv">View full resume →</a></p>
      </section>

      <section class="contact">
        <h2>Let's work together</h2>
        <p>
          Need a solid backend, better infrastructure or process automation? Email me at
          <a href={`mailto:${AUTHOR.email}`}>{AUTHOR.email}</a> or connect on
          <a href={AUTHOR.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>.
        </p>
      </section>
    </main>
    <Footer />
    <style>
      .hero {
        padding: 1em 0 2em 0;
      }
      .eyebrow {
        color: rgb(var(--gray));
        margin-bottom: 0.25em;
      }
      h1 {
        font-size: 2.4em;
      }
      .amp {
        color: var(--accent);
      }
      .lead {
        font-size: 1.1em;
      }
      .cta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6em;
        margin-top: 1em;
      }
      .btn {
        display: inline-block;
        padding: 0.55em 1.1em;
        border: 2px solid var(--accent);
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
      }
      .btn.primary {
        background: var(--accent);
        color: #fff;
      }
      section {
        margin-bottom: 2.5em;
      }
      h2 {
        font-size: 1.6em;
        margin-bottom: 0.75em;
      }
      h3 {
        font-size: 1.15em;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1em;
      }
      .grid article {
        border: 1px solid rgb(var(--gray-light));
        border-radius: 8px;
        padding: 1em;
        background: #fff;
      }
      .grid p {
        font-size: 0.85em;
        margin-bottom: 0;
      }
      .stack {
        list-style: none;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5em;
      }
      .stack li {
        background: rgb(var(--gray-light));
        border-radius: 999px;
        padding: 0.25em 0.9em;
        font-size: 0.85em;
      }
      .timeline {
        list-style: none;
        padding: 0;
      }
      .timeline li {
        padding: 0.5em 0;
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .dates {
        display: block;
        color: rgb(var(--gray));
        font-size: 0.85em;
      }
      .contact {
        background: rgb(var(--gray-light));
        border-radius: 8px;
        padding: 1.5em;
      }
      .contact p {
        margin-bottom: 0;
      }
    </style>
  </body>
</html>
